# .env.production.example - Example environment variables for production
# Copy this file to .env.production and update the values

# Public variables (accessible in the browser)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX  # Your Google Analytics Measurement ID
NEXT_PUBLIC_SITE_URL=https://mindscraft.dev  # Your production site URL

# NextAuth configuration
NEXTAUTH_URL=https://mindscraft.dev  # Your production site URL (same as NEXT_PUBLIC_SITE_URL)
NEXTAUTH_SECRET=generate-a-secure-random-string-here  # Generate a secure random string for production

# Database configuration
# If you're switching to PostgreSQL or MySQL, uncomment and set this:
# DATABASE_URL="postgresql://username:password@hostname:port/database"
# DATABASE_URL="mysql://username:password@hostname:port/database"

# Note: For Vercel deployment, set these variables in the Vercel dashboard
# For other hosting providers, follow their documentation for setting environment variables
