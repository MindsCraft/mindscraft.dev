# .env.example - Example environment variables for the project

# Public variables (accessible in the browser)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX  # Google Analytics Measurement ID
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # Site URL for local development

# NextAuth configuration
NEXTAUTH_URL=http://localhost:3000           # URL for NextAuth authentication
NEXTAUTH_SECRET=your-secret-key-here         # Secret key for NextAuth (generate a secure random string)

# Database configuration
# Note: This project uses SQLite with a hardcoded path in schema.prisma
# If you switch to another database provider, uncomment and set this:
# DATABASE_URL="postgresql://username:password@localhost:5432/mydb"
